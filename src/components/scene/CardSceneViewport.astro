---
import { SceneViewportController } from './SceneViewportController'
import type { SceneNavSlide, SceneTone } from '../../theme/sceneTheme'

interface Slide {
	id: string
	Component: any
	props?: Record<string, unknown>
	navTone: SceneTone
}

const { slides } = Astro.props as { slides: Slide[] }

const navSlides: SceneNavSlide[] = slides.map(({ id, navTone }) => ({ id, navTone }))
---

<SceneViewportController client:idle slides={navSlides}>
	{
		slides.map(({ id, Component, props = {} }, index) => (
			<section
				class:list={[
					'w-full shrink-0 py-3 md:py-0',
					id === 'experience' || id === 'stack' ? 'md:block' : 'flex items-center justify-center',
					index === 0
						? 'md:min-h-[calc(100dvh-(var(--page-padding)*2))]'
						: 'md:min-h-[min(calc(100dvh-(var(--page-padding)*2)),54rem)]'
				]}
				data-scene-slide={id}
			>
				<Component {...props} />
			</section>
		))
	}
</SceneViewportController>
