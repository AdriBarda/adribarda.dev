---
import { sceneToneAccentClasses, type SceneTone } from '../../theme/sceneTheme'
import type { SectionEntry, SectionGroup } from '../../content/sections'
import GlassCard from '../ui/GlassCard.astro'

const { group, accentTone } = Astro.props as { group?: SectionGroup; accentTone?: SceneTone }
const experience = group?.entries.find((entry) => entry.data.section === 'experience')
const impact = group?.entries.find((entry) => entry.data.section === 'impact')
const accentClass = accentTone ? sceneToneAccentClasses[accentTone] : ''

function getHighlights(entry?: SectionEntry) {
	return entry?.data.highlights.slice(0, 3) ?? []
}
---

<div class="grid w-full gap-4 md:grid-cols-[1.45fr_1fr] md:grid-rows-[minmax(0,1fr)_minmax(0,1fr)]">
	<GlassCard class="p-6 sm:p-8 md:row-span-2 lg:p-10">
		<div class:list={["pointer-events-none absolute inset-y-0 left-0 z-10 w-1", accentClass]}></div>
		<div class="flex h-full flex-col justify-between gap-8">
			<div>
				{experience?.data.eyebrow && (
					<p class="text-[0.78rem] uppercase tracking-[0.18em] text-app-text/58">{experience.data.eyebrow}</p>
				)}
				<h2 class="mt-4 max-w-[12ch] text-balance text-[clamp(2.4rem,5vw,4.8rem)] leading-[0.95] font-semibold tracking-[-0.05em]">
					{experience?.data.title ?? 'Missing experience title.'}
				</h2>
				<p class="mt-5 max-w-2xl text-[clamp(1rem,1.35vw,1.1rem)] leading-[1.7] text-app-muted">
					{experience?.data.summary ?? 'Missing experience summary.'}
				</p>
			</div>

			<div class="grid gap-3 border-t border-app-border pt-5 text-sm leading-[1.65] text-app-muted sm:grid-cols-3">
				{
					getHighlights(experience).map((note) => (
						<div class="pr-4 text-app-text">{note}</div>
					))
				}
			</div>
		</div>
	</GlassCard>

	<GlassCard class="p-5 lg:p-6">
		<div class="flex h-full flex-col justify-between gap-4">
			<div>
				{impact?.data.eyebrow && (
					<p class="text-[0.76rem] uppercase tracking-[0.18em] text-app-text/58">{impact.data.eyebrow}</p>
				)}
				<p class="mt-3 text-base leading-[1.7] text-app-text">{impact?.data.title ?? 'Missing impact title.'}</p>
			</div>
			<p class="text-sm leading-[1.7] text-app-muted">{impact?.data.summary ?? 'Missing impact summary.'}</p>
		</div>
	</GlassCard>

	<GlassCard class="p-5 lg:p-6">
		<div class="flex h-full flex-col justify-between gap-4">
			<div>
				<p class="text-[0.76rem] uppercase tracking-[0.14em] text-app-muted">Highlights</p>
				<p class="mt-3 text-base leading-[1.7] text-app-text">{(impact?.data.highlights ?? []).join(' / ') || 'Missing impact highlights.'}</p>
			</div>
			<p class="text-sm leading-[1.7] text-app-muted">{impact?.body ?? 'Missing impact body.'}</p>
		</div>
	</GlassCard>
</div>
