---
import { sceneToneAccentClasses, type SceneTone } from '../../theme/sceneTheme'
import type { SectionGroup } from '../../content/sections'
import GlassCard from '../ui/GlassCard.astro'
import { ExperienceTimelineController } from './ExperienceTimelineController'

const { group, accentTone } = Astro.props as { group?: SectionGroup; accentTone?: SceneTone }
const experience = group?.entries.find((entry) => entry.data.section === 'experience')
const impact = group?.entries.find((entry) => entry.data.section === 'impact')
const accentClass = accentTone ? sceneToneAccentClasses[accentTone] : ''

const timeline = experience?.data.items ?? []
const timelineScrollHeight = `calc((100dvh - (var(--page-padding) * 2)) + ${Math.max(timeline.length - 1, 1) * 22}rem)`

function getPeriodYear(period?: string) {
	const years = period?.match(/\b\d{4}\b/g)

	return years?.at(-1)
}

const earliestYear = getPeriodYear(timeline.at(-1)?.period)
const latestYear = getPeriodYear(timeline[0]?.period)
const experienceMeta = [
	earliestYear && latestYear ? `${earliestYear} - ${latestYear}` : undefined,
	timeline.length > 0 ? `${timeline.length} roles` : undefined
]
	.filter(Boolean)
	.join(' · ')
---

<div data-experience-section class="w-full md:min-h-(--experience-scroll-height)" style={`--experience-scroll-height: ${timelineScrollHeight};`}>
	<ExperienceTimelineController client:load />
	<div data-experience-pin class="grid w-full gap-4 md:sticky md:top-[12vh] md:grid-cols-[1.45fr_1fr] md:grid-rows-[minmax(0,1fr)_minmax(0,1fr)]">
	<GlassCard data-bento-role="left" class="p-6 sm:p-8 md:row-span-2 lg:p-9">
		<div class:list={["pointer-events-none absolute inset-y-0 left-0 z-10 w-1", accentClass]}></div>
		<div class="flex h-full flex-col justify-between gap-8">
			<div>
				{experience?.data.eyebrow && (
					<p class="text-[0.78rem] uppercase tracking-[0.18em] text-app-text/58">{experience.data.eyebrow}</p>
				)}
				{experienceMeta && (
					<p class="mt-3 text-[0.72rem] uppercase tracking-[0.16em] text-app-text/46">{experienceMeta}</p>
				)}
				<h2 class="mt-4 max-w-[14ch] text-balance text-[clamp(2.7rem,5.4vw,5.1rem)] leading-[0.92] font-semibold tracking-[-0.055em] text-app-text">
					{experience?.data.title ?? 'Missing experience title.'}
				</h2>
				<p class="mt-5 max-w-2xl text-[clamp(1rem,1.35vw,1.1rem)] leading-[1.7] text-app-muted">
					{experience?.data.summary ?? 'Missing experience summary.'}
				</p>
			</div>

			<div class="flex flex-col gap-4 pt-1">
				<p class="text-[0.72rem] uppercase tracking-[0.16em] text-app-text/46">Selected roles</p>
				<div data-experience-timeline-viewport class="relative pl-3 md:h-[24rem] md:overflow-x-visible md:overflow-y-hidden">
					<ol data-experience-timeline-track class="relative border-l border-app-border/80 md:will-change-transform">
					{timeline.length > 0 ? (
						timeline.map((item) => (
							<li data-experience-timeline-item class="relative ml-5 pb-5 last:pb-0 sm:ml-6">
								<span
									class:list={[
										'absolute -left-[1.72rem] top-1.5 size-3 rounded-full border-2 border-[color-mix(in_srgb,var(--app-bg)_82%,transparent)] shadow-[0_0_0_4px_color-mix(in_srgb,var(--app-bg)_86%,transparent)] sm:-left-[1.97rem]',
										item.highlight ? accentClass : 'bg-app-text/26'
									]}
								></span>

								<div class="min-w-0 px-1 py-1 sm:px-2 sm:py-1.5">
									<time class="text-[0.68rem] uppercase tracking-[0.14em] text-app-text/52">
										{item.period}
									</time>

									<div class="mt-3">
										<p class="text-base font-medium leading-tight text-app-text">{item.role}</p>
										<p class="mt-1 text-sm font-medium text-app-text/82">
											<span>{item.company}</span>
											{item.location && <span class="text-app-text/58">{` - ${item.location}`}</span>}
										</p>
									</div>

									<p class="mt-3 text-sm leading-[1.72] text-app-muted">{item.description}</p>
									<ul class="mt-3 flex flex-wrap gap-x-3 gap-y-1.5 text-[0.75rem] leading-[1.45] text-app-text/66">
										{item.highlights.map((highlight) => (
											<li>{highlight}</li>
										))}
									</ul>
								</div>
							</li>
						))
					) : (
						<p class="text-sm leading-[1.7] text-app-muted">Missing experience timeline.</p>
					)}
					</ol>
				</div>
			</div>
		</div>
	</GlassCard>

	<GlassCard data-bento-role="right" class="h-full p-4 sm:p-5 lg:p-6">
		<div class="flex h-full flex-col gap-4">
			{impact?.data.eyebrow && (
				<p class="text-[0.76rem] uppercase tracking-[0.18em] text-app-text/58">{impact.data.eyebrow}</p>
			)}
			<div class="flex flex-col gap-3 pt-1 sm:pt-2">
				<ul class="space-y-3.5">
					{impact?.data.highlights?.length ? (
						impact.data.highlights.map((highlight) => (
							<li class="grid grid-cols-[auto_1fr] gap-3">
								<span class="mt-[0.42rem] size-1.5 rounded-full bg-app-text/48"></span>
								<p class="text-sm leading-[1.72] text-app-text/86">{highlight}</p>
							</li>
						))
					) : (
						<li class="text-sm leading-[1.7] text-app-muted">Missing impact highlights.</li>
					)}
				</ul>
			</div>
		</div>
	</GlassCard>

	<GlassCard data-bento-role="right" class="p-4 sm:p-5 lg:p-6">
		<div class="flex h-full flex-col gap-4">
			<div>
				<p class="text-[0.76rem] uppercase tracking-[0.14em] text-app-muted">Approach</p>
			</div>
			<div class="flex flex-col gap-3 pt-1 sm:pt-2">
				<p class="text-base leading-[1.62] text-app-text/88">
					{impact?.data.title ?? 'Missing impact title.'}
				</p>
				<p class="text-sm leading-[1.72] text-app-muted">{impact?.body ?? 'Missing impact body.'}</p>
			</div>
		</div>
	</GlassCard>
</div>
</div>
