---
import { render } from 'astro:content'
import { sceneToneAccentClasses, type SceneTone } from '../../theme/sceneTheme'
import type { SectionGroup } from '../../content/sections'
import GlassCard from '../ui/GlassCard.astro'

const { group, accentTone } = Astro.props as { group?: SectionGroup; accentTone?: SceneTone }
const entry = group?.entries[0]
const renderedEntry = entry ? await render(entry) : undefined
const accentClass = accentTone ? sceneToneAccentClasses[accentTone] : ''

const pillClass = [
	'rounded-full border border-white/35 px-4 py-2.5 text-sm text-app-text',
	'bg-white/18 backdrop-blur-[6px] backdrop-saturate-125 dark:bg-white/8 dark:border-white/15'
].join(' ')
---

<GlassCard class="w-full p-6 sm:p-8 lg:p-9">
	<div class:list={["pointer-events-none absolute inset-y-0 left-0 z-10 w-1", accentClass]}></div>
	<div class="grid gap-8 lg:grid-cols-[minmax(0,1.28fr)_minmax(17rem,0.82fr)] lg:gap-9">
		<div class="flex flex-col justify-between gap-6">
			<div>
				{entry?.data.eyebrow && (
					<p class="text-[0.78rem] uppercase tracking-[0.18em] text-app-text/58">{entry.data.eyebrow}</p>
				)}

				<p class="mt-5 text-sm tracking-[0.02em] text-app-muted sm:text-base">{entry?.data.section ?? 'about-me'}</p>

				<h1 class="mt-4 max-w-[10ch] text-balance text-[clamp(2.7rem,6vw,5.7rem)] leading-[0.92] font-semibold tracking-[-0.06em]">
					{entry?.data.title ?? 'Missing about title.'}
				</h1>

				<p class="mt-5 max-w-lg text-[clamp(0.98rem,1.35vw,1.08rem)] leading-[1.66] text-app-muted">
					{entry?.data.summary ?? 'Missing about summary.'}
				</p>
			</div>

			<div class="flex flex-wrap gap-2.5">
				{
					(entry?.data.highlights ?? []).map((area) => (
						<span class={pillClass}>{area}</span>
					))
				}
			</div>
		</div>

		<div class="flex flex-col justify-end gap-6 lg:pl-5">
			<div class="max-w-104 self-start border-l border-app-border pl-6">
				<p class="text-[0.76rem] uppercase tracking-[0.14em] text-app-muted">Notes</p>
				<div class="mt-4 text-[0.98rem] leading-[1.72] text-app-text text-balance">
					{renderedEntry?.Content ? <renderedEntry.Content /> : <p>Missing about body.</p>}
				</div>
			</div>

			<div class="grid max-w-104 gap-3 border-t border-app-border pt-4 text-sm leading-[1.62] text-app-muted sm:grid-cols-2 lg:grid-cols-1">
				<p>{entry?.data.summary ?? 'Missing about summary.'}</p>
				<p>{entry?.data.eyebrow ?? 'About me'}</p>
			</div>
		</div>
	</div>
</GlassCard>
