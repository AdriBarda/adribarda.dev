---
import { render } from 'astro:content'
import { sceneToneAccentClasses, type SceneTone } from '../../theme/sceneTheme'
import type { SectionGroup } from '../../content/sections'
import GlassCard from '../ui/GlassCard.astro'

const { group, accentTone } = Astro.props as { group?: SectionGroup; accentTone?: SceneTone }
const entry = group?.entries[0]
const renderedEntry = entry ? await render(entry) : undefined
const accentClass = accentTone ? sceneToneAccentClasses[accentTone] : ''

const languageGroups = (entry?.data.languages ?? []).reduce<Array<{ label: string; details: string[] }>>((groups, item) => {
	const separatorIndex = item.indexOf(':')
	const label = separatorIndex >= 0 ? item.slice(0, separatorIndex).trim() : item.trim()
	const detail = separatorIndex >= 0 ? item.slice(separatorIndex + 1).trim() : ''
	const previousGroup = groups.at(-1)

	if (previousGroup?.label === label && detail) {
		previousGroup.details.push(detail)
		return groups
	}

	groups.push({
		label,
		details: detail ? [detail] : []
	})

	return groups
}, [])
---

<div data-about-static class="grid w-full gap-4 md:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)] md:grid-rows-[minmax(0,1fr)_minmax(0,1fr)]">
	<GlassCard class="p-6 sm:p-8 md:row-span-2 lg:p-9">
		<div class:list={["pointer-events-none absolute inset-y-0 left-0 z-10 w-1", accentClass]}></div>
		<div class="flex h-full flex-col gap-6">
			<div>
				{entry?.data.eyebrow && (
					<p class="text-[0.78rem] uppercase tracking-[0.18em] text-app-text/58">{entry.data.eyebrow}</p>
				)}

				<h1 class="mt-4 max-w-[12ch] text-balance text-[clamp(2.4rem,5.2vw,4.8rem)] leading-[0.94] font-semibold tracking-[-0.055em] text-app-text">
					Outside work.
				</h1>

				<p class="mt-4 max-w-lg text-[clamp(0.98rem,1.18vw,1.04rem)] leading-[1.68] text-app-text/74 text-pretty">
					{entry?.data.summary ?? 'Missing about summary.'}
				</p>
			</div>

			<div class="text-[0.98rem] leading-[1.74] text-app-text/88 text-pretty [&_p+p]:mt-4">
				{renderedEntry?.Content ? <renderedEntry.Content /> : <p>Missing about body.</p>}
			</div>
		</div>
	</GlassCard>

	<GlassCard class="h-full p-5 lg:p-6">
		<div class="flex h-full flex-col gap-4">
			<div>
				<p class="text-[0.76rem] uppercase tracking-[0.18em] text-app-text/58">Languages</p>
			</div>

			<ul class="grid gap-3 text-sm leading-[1.7] text-app-text/84">
				{languageGroups.map((languageGroup) => (
					<li class="border-t border-app-border/70 pt-3 first:border-t-0 first:pt-0">
						<p class="font-medium text-app-text">{languageGroup.label}</p>
						<div class="mt-1 grid gap-1 text-app-text/74">
							{languageGroup.details.map((detail) => (
								<p>{detail}</p>
							))}
						</div>
					</li>
				))}
			</ul>
		</div>
	</GlassCard>

	<GlassCard class="p-5 lg:p-6">
		<div class="flex h-full flex-col justify-between gap-4">
			<div>
				<p class="text-[0.76rem] uppercase tracking-[0.14em] text-app-text/58">Education</p>
			</div>

			<div class="flex flex-col gap-3 text-app-text/82">
				<p class="text-base leading-[1.55] font-medium text-app-text">
					{entry?.data.education?.institution ?? 'Missing education institution.'}
				</p>
				<p class="text-sm leading-[1.72] text-app-text/74 text-pretty">
					{entry?.data.education?.program ?? 'Missing education program.'}
				</p>
				<p class="text-[0.76rem] uppercase tracking-[0.16em] text-app-text/56">
					{entry?.data.education?.period ?? 'Missing education period.'}
				</p>
			</div>
		</div>
	</GlassCard>
</div>
