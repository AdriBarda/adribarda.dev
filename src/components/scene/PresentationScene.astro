---
import { render } from 'astro:content'
import { sceneToneAccentClasses, type SceneTone } from '../../theme/sceneTheme'
import type { SectionGroup } from '../../content/sections'
import GithubIcon from '../../assets/tech-stack/github.svg'
import GlassCard from '../ui/GlassCard.astro'

const { group, accentTone } = Astro.props as { group?: SectionGroup; accentTone?: SceneTone }
const entry = group?.entries[0]
const renderedEntry = entry ? await render(entry) : undefined
const accentClass = accentTone ? sceneToneAccentClasses[accentTone] : ''

const socialLinkClass = [
	'group relative inline-flex h-12 items-center justify-start gap-2.5 overflow-hidden rounded-full border px-4 text-sm font-medium',
	'text-white border-[color-mix(in_srgb,var(--scene-accent-presentation)_74%,#7c3aed)] bg-[color-mix(in_srgb,var(--scene-accent-presentation)_82%,#7c3aed)]',
	'shadow-[0_8px_22px_rgba(109,40,217,0.18)]',
	'transition-[width,background-color,border-color,box-shadow] duration-300 ease-in-out hover:border-[color-mix(in_srgb,var(--scene-accent-presentation)_82%,#8b5cf6)] hover:bg-[color-mix(in_srgb,var(--scene-accent-presentation)_88%,#8b5cf6)] hover:shadow-[0_14px_26px_rgba(109,40,217,0.24)]',
	'dark:border-[color-mix(in_srgb,var(--scene-accent-presentation)_58%,white_12%)] dark:bg-[color-mix(in_srgb,var(--scene-accent-presentation)_58%,#4c1d95)]',
	'dark:text-[color-mix(in_srgb,white_96%,#f5d0fe)] dark:shadow-[0_10px_24px_rgba(76,29,149,0.26)] dark:hover:border-[color-mix(in_srgb,var(--scene-accent-presentation)_70%,white_14%)] dark:hover:bg-[color-mix(in_srgb,var(--scene-accent-presentation)_68%,#5b21b6)] dark:hover:shadow-[0_16px_30px_rgba(76,29,149,0.34)]',
	'md:w-12 md:px-3.5 md:hover:w-32'
].join(' ')

const normalizeUrl = (url?: string) => {
	if (!url) {
		return '#'
	}

	return url.startsWith('http://') || url.startsWith('https://') ? url : `https://${url}`
}

const meta = entry?.data.meta ?? []
const profileLabel = entry?.data.profileLabel
const details = entry?.data.details ?? []
const github = entry?.data.socials?.github
const linkedin = entry?.data.socials?.linkedin
const githubUrl = normalizeUrl(github?.url)
const linkedinUrl = normalizeUrl(linkedin?.url)
const title = entry?.data.title ?? 'Missing presentation title.'
const role = entry?.data.role ?? 'Frontend Engineer'
const titleMatch = title.match(/^(.*?)(\s*[\p{Extended_Pictographic}\uFE0F]+)$/u)
const titleText = titleMatch?.[1]?.trim() ?? title
const titleEmoji = titleMatch?.[2]?.trim() ?? ''
---

<div class="grid w-full gap-4 lg:grid-cols-[minmax(0,1.28fr)_minmax(18rem,0.82fr)]">
	<GlassCard data-bento-role="hero" class="w-full p-5 sm:p-8 lg:col-span-2 lg:p-10">
		<div class:list={["pointer-events-none absolute inset-y-0 left-0 z-10 w-1", accentClass]}></div>
		<div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_18%_18%,rgba(255,255,255,0.16),transparent_28%)] dark:bg-[radial-gradient(circle_at_18%_18%,rgba(255,255,255,0.08),transparent_28%)]"></div>

		<div class="flex flex-col gap-5 lg:gap-6">
			<div class="flex flex-col gap-3">
				{entry?.data.eyebrow && (
					<p class="text-[0.78rem] uppercase tracking-[0.18em] text-app-text/58">{entry.data.eyebrow}</p>
				)}

				{meta.length > 0 && (
					<div class="flex flex-wrap gap-x-4 gap-y-2 text-[0.74rem] uppercase tracking-[0.16em] text-app-text/58">
						{meta.map((item) => (
							<span>{item}</span>
						))}
					</div>
				)}
			</div>

			<div class="flex flex-col gap-2">
				<p class="text-[clamp(1.55rem,7vw,2.45rem)] leading-[1.04] font-semibold tracking-[-0.04em] text-app-text text-balance">
					{titleText}
					{titleEmoji && <span class="ml-2 inline-block align-middle leading-none">{titleEmoji}</span>}
				</p>

				<h1 class="lava-title max-w-full overflow-visible whitespace-normal pb-[0.14em] text-[clamp(2.8rem,15vw,5rem)] leading-[0.96] font-semibold tracking-[-0.06em] text-transparent bg-clip-text sm:whitespace-nowrap sm:text-[clamp(3.25rem,5.5vw,5rem)] sm:leading-[1.02] sm:tracking-[-0.055em]">
					{role}
				</h1>
			</div>

			<div class="flex flex-col gap-4 lg:max-w-3xl">
				<p class="w-full text-[clamp(1.04rem,1.08vw,1.06rem)] leading-[1.72] text-app-text/80 text-pretty sm:max-w-160">
					{entry?.data.summary ?? 'Missing presentation summary.'}
				</p>

				{(github || linkedin) && (
					<div class="flex flex-wrap gap-3 pt-0.5">
						{github && (
							<a href={githubUrl} target="_blank" rel="noopener noreferrer" class={socialLinkClass}>
								<GithubIcon aria-hidden="true" class="size-4.5 shrink-0 fill-current text-current" />
								<span class="inline-flex whitespace-nowrap md:overflow-hidden md:transition-all md:duration-200 md:ease-in-out md:group-hover:max-w-16 md:group-hover:translate-x-0 md:group-hover:opacity-100 md:[@media(hover:hover)]:max-w-0 md:[@media(hover:hover)]:translate-x-[-0.35rem] md:[@media(hover:hover)]:opacity-0">
									{github.label}
								</span>
							</a>
						)}

						{linkedin && (
							<a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class={socialLinkClass}>
								<svg aria-hidden="true" class="size-4.5 shrink-0 fill-current text-current" viewBox="0 0 24 24"><path d="M6.94 8.5H3.56V20h3.38zm.22-3.55C7.16 3.87 6.37 3 5.27 3s-1.89.87-1.89 1.95c0 1.06.77 1.94 1.85 1.94h.02c1.12 0 1.91-.88 1.91-1.94m13.46 8.01c0-3.47-1.81-5.08-4.22-5.08-1.94 0-2.81 1.08-3.29 1.85V8.5H9.73c.04.82 0 11.5 0 11.5h3.38v-6.42c0-.34.02-.68.12-.92.27-.68.88-1.38 1.91-1.38 1.35 0 1.89 1.04 1.89 2.56V20h3.37v-6.04Z"/></svg>
								<span class="inline-flex whitespace-nowrap md:overflow-hidden md:transition-all md:duration-200 md:ease-in-out md:group-hover:max-w-16 md:group-hover:translate-x-0 md:group-hover:opacity-100 md:[@media(hover:hover)]:max-w-0 md:[@media(hover:hover)]:translate-x-[-0.35rem] md:[@media(hover:hover)]:opacity-0">
									{linkedin.label}
								</span>
							</a>
						)}
					</div>
				)}
			</div>
		</div>
	</GlassCard>

	<GlassCard data-bento-role="left" class="p-5 sm:p-6 lg:p-7">
		{profileLabel && <p class="text-[0.76rem] uppercase tracking-[0.16em] text-app-text/58">{profileLabel}</p>}
		<div class="mt-3 w-full text-[1rem] leading-[1.72] text-app-text/90 text-pretty [&_p+p]:mt-3">
			{renderedEntry?.Content ? <renderedEntry.Content /> : <p>Missing presentation body.</p>}
		</div>
	</GlassCard>

	<GlassCard data-bento-role="right" class="p-5 sm:p-6 lg:p-7">
		<div class="flex h-full flex-col gap-4 text-[0.96rem] leading-[1.58] text-app-text/68">
			<div class="flex flex-col gap-3">
				{details.length > 0 ? (
					details.map((detail) => (
						<div>
							<p class="text-[0.72rem] uppercase tracking-[0.16em] text-app-text/46">{detail.label}</p>
							<p class="mt-2 flex items-center gap-2 text-app-text/88">
								{detail.label === 'Status' && detail.value === 'Open To Work' && (
									<span class="relative flex size-2.5 shrink-0 items-center justify-center">
										<span class="absolute inline-flex size-full rounded-full bg-emerald-400/70 animate-ping motion-reduce:hidden"></span>
										<span class="relative inline-flex size-2 rounded-full bg-emerald-400"></span>
									</span>
								)}
								<span>{detail.value}</span>
							</p>
						</div>
					))
				) : (
					<p class="text-app-text/66">Missing presentation details.</p>
				)}
			</div>
		</div>
	</GlassCard>
</div>
