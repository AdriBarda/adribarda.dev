---
interface Props {
	as?: keyof HTMLElementTagNameMap
	class?: string
	[key: string]: unknown
}

const { as = 'article', class: className = '', ...rest } = Astro.props
const Tag = as

const glassClass = [
	'relative overflow-hidden rounded-[16px] border border-[rgba(255,255,255,0.24)]',
	'bg-[rgba(255,255,255,0.63)] shadow-[0_4px_30px_rgba(0,0,0,0.1)]',
	'backdrop-blur-[10.2px] backdrop-saturate-140',
	'dark:border-[rgba(40,40,40,0.24)] dark:bg-[rgba(40,40,40,0.72)]',
	'dark:backdrop-blur-[12.4px] dark:backdrop-saturate-125'
].join(' ')
---

<Tag {...rest} data-glass-card class:list={[glassClass, className]}>
	<slot />
</Tag>
