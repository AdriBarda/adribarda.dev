---
interface Props {
	as?: keyof HTMLElementTagNameMap
	class?: string
	[key: string]: unknown
}

const { as = 'article', class: className = '', ...rest } = Astro.props
const Tag = as

const glassClass = [
	'relative overflow-hidden rounded-[16px] border border-white/55',
	'bg-white/44 backdrop-blur-[14px] backdrop-saturate-145',
	'shadow-[0_14px_40px_rgba(15,23,42,0.12)]',
	'dark:border-white/14 dark:bg-white/9 dark:shadow-[0_18px_48px_rgba(0,0,0,0.34)]'
].join(' ')
---

<Tag {...rest} data-glass-card class:list={[glassClass, className]}>
	<slot />
</Tag>
