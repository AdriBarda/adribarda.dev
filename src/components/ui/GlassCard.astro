---
interface Props {
	as?: keyof HTMLElementTagNameMap
	class?: string
	[key: string]: unknown
}

const { as = 'article', class: className = '', ...rest } = Astro.props
const Tag = as

const glassClass = [
	'relative overflow-hidden rounded-[16px] border border-white/55',
	'bg-white/88 shadow-[0_10px_24px_rgba(15,23,42,0.08)]',
	'dark:border-white/12 dark:bg-[rgba(15,23,42,0.84)] dark:shadow-[0_12px_28px_rgba(0,0,0,0.22)]',
	'md:bg-white/44 md:backdrop-blur-[14px] md:backdrop-saturate-145',
	'md:shadow-[0_14px_40px_rgba(15,23,42,0.12)]',
	'dark:md:bg-white/9 dark:md:shadow-[0_18px_48px_rgba(0,0,0,0.34)]'
].join(' ')
---

<Tag {...rest} data-glass-card class:list={[glassClass, className]}>
	<slot />
</Tag>
