---
import AboutScene from './AboutScene.astro'
import CardSceneViewport from './CardSceneViewport.astro'
import ExperienceScene from './ExperienceScene.astro'
import PresentationScene from './PresentationScene.astro'
import StackScene from './StackScene.astro'
import type { SectionGroup } from '../content/sections'

const { sectionGroups } = Astro.props as { sectionGroups: SectionGroup[] }

const slides = [
	{ id: 'presentation', Component: PresentationScene, props: { group: sectionGroups.find((group) => group.scene === 1) } },
	{ id: 'experience', Component: ExperienceScene, props: { group: sectionGroups.find((group) => group.scene === 2) } },
	{ id: 'stack', Component: StackScene, props: { group: sectionGroups.find((group) => group.scene === 3) } },
	{ id: 'about-me', Component: AboutScene, props: { group: sectionGroups.find((group) => group.scene === 4) } }
]
---

<CardSceneViewport slides={slides} />
