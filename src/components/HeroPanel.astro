---
import AboutScene from './AboutScene.astro'
import CardSceneViewport from './CardSceneViewport.astro'
import ExperienceScene from './ExperienceScene.astro'
import PresentationScene from './PresentationScene.astro'
import StackScene from './StackScene.astro'
import type { SceneTone } from './sceneTheme'
import type { SectionGroup } from '../content/sections'

const { sectionGroups } = Astro.props as { sectionGroups: SectionGroup[] }

const slides = [
	{ id: 'presentation', navTone: 'presentation' as SceneTone, Component: PresentationScene, props: { group: sectionGroups.find((group) => group.scene === 1), accentTone: 'presentation' as SceneTone } },
	{ id: 'experience', navTone: 'experience' as SceneTone, Component: ExperienceScene, props: { group: sectionGroups.find((group) => group.scene === 2), accentTone: 'experience' as SceneTone } },
	{ id: 'stack', navTone: 'stack' as SceneTone, Component: StackScene, props: { group: sectionGroups.find((group) => group.scene === 3), accentTone: 'stack' as SceneTone } },
	{ id: 'about-me', navTone: 'about-me' as SceneTone, Component: AboutScene, props: { group: sectionGroups.find((group) => group.scene === 4), accentTone: 'about-me' as SceneTone } }
]
---

<CardSceneViewport slides={slides} />
