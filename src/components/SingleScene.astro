---
import type { SectionGroup } from '../content/sections'
import GlassCard from './GlassCard.astro'

const { group } = Astro.props as { group?: SectionGroup }
const entry = group?.entries[0]

const pillClass = [
	'rounded-full border border-white/35 px-4 py-2.5 text-sm text-app-text',
	'bg-white/18 backdrop-blur-[6px] backdrop-saturate-125 dark:bg-white/8 dark:border-white/15'
].join(' ')

const chipClass = [
	'inline-flex items-center rounded-full border border-white/35 px-3 py-1.5',
	'bg-white/18 text-[0.78rem] uppercase tracking-[0.14em] text-app-muted',
	'backdrop-blur-[6px] backdrop-saturate-125 dark:border-white/15 dark:bg-white/8'
].join(' ')
---

<GlassCard class="w-full p-6 sm:p-8 lg:p-12">
	<div class="grid gap-10 lg:grid-cols-[minmax(0,1.45fr)_minmax(18rem,0.8fr)] lg:gap-12">
		<div class="flex flex-col justify-between gap-8">
			<div>
				<div class={chipClass}>{entry?.data.eyebrow ?? 'Section'}</div>

				<p class="mt-5 text-sm tracking-[0.02em] text-app-muted sm:text-base">
					{entry?.data.section ?? 'section'}
				</p>

				<h1 class="mt-4 max-w-[11ch] text-balance text-[clamp(3rem,7vw,6.6rem)] leading-[0.92] font-semibold tracking-[-0.06em]">
					{entry?.data.title ?? 'Missing section title.'}
				</h1>

				<p class="mt-6 max-w-2xl text-[clamp(1rem,1.5vw,1.2rem)] leading-[1.7] text-app-muted">
					{entry?.data.summary ?? 'Missing section summary.'}
				</p>
			</div>

			<div class="flex flex-wrap gap-3">
				{
					(entry?.data.highlights ?? []).map((area) => (
						<span class={pillClass}>{area}</span>
					))
				}
			</div>
		</div>

		<div class="flex flex-col justify-end gap-5 lg:pl-6">
			<GlassCard as="div" class="p-5">
				<p class="text-[0.76rem] uppercase tracking-[0.14em] text-app-muted">Summary</p>
				<p class="mt-3 text-base leading-[1.7] text-app-text sm:text-[1.02rem]">
					{entry?.body ?? 'Missing section body.'}
				</p>
			</GlassCard>

			<div class="grid gap-4 border-t border-app-border pt-5 text-sm leading-[1.7] text-app-muted sm:grid-cols-2 lg:grid-cols-1">
				<p>{entry?.data.summary ?? 'Missing section summary.'}</p>
				<p>{entry?.data.eyebrow ?? 'Section'}</p>
			</div>
		</div>
	</div>
</GlassCard>
