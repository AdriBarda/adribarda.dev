---
import { ThemeToggle } from '../components/theme/ThemeToggle'
import '../styles/global.css'
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
		<script is:inline src="/theme-init.js"></script>
	</head>
	<body class="bg-app-bg text-app-text">
		<div class="pointer-events-none fixed top-[max(12px,calc(var(--page-padding)-32px))] right-[max(12px,calc(var(--page-padding)-4px))] z-30">
			<div class="flex justify-end">
				<ThemeToggle client:only="react" />
			</div>
		</div>
		<main>
			<slot />
		</main>
		<slot name="footer" />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100dvh;
	}

	body {
		--page-padding: clamp(16px, 4vw, 48px);
	}

	main {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		min-height: 100dvh;
		padding: var(--page-padding);
		box-sizing: border-box;
	}

	@media (min-width: 768px) {
		body {
			overflow: hidden;
		}

		main {
			height: 100dvh;
		}
	}
</style>
